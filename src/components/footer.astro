---
import Disclaimer from '../components/md/disclaimer.md';

interface Props {
  colorLightBlue: string;
  colorMediumBlue: string;
  colorAnthracite: string;
  colorOrange: string;
}
const { colorLightBlue, colorMediumBlue, colorAnthracite, colorOrange } = Astro.props;
---

<!-- CSS -------------------------------------------------------- -->
<!-- Make it global to also have it applied to included components -->
<style is:global define:vars={{ colorLightBlue, colorMediumBlue, colorAnthracite, colorOrange }}> 

    footer {
        display:                flex;
        justify-content:        center;
        align-items:            center;        
        position:               relative;
        margin:                 0;
        padding:                0;
        background-color:       var(--colorAnthracite);
        width:                  100%;
        text-align:             center;
    }

    .disclaimer {
        font-size:              0.8rem;
        color:                  white;
        padding-bottom:         1rem;
    }

    .disclaimer a {
        color:                  white;
    }

    .banner {
        display:                flex;
        width:                  100%;
        height:                 auto;
        margin:                 0;
        padding:                0;
        margin-bottom:          -3px;
        background-color:       white;
    }


/***** Additional options for Responsive Web Design *****/

@media screen and (max-width: 1250px) {

    footer {
        display:            flex;
        flex-direction:     column;
        align-items:        center;
    }
}      

</style>

<!-- HTML ------------------------------------------------------- -->
<footer>

    <div class="disclaimer">

        <img  class="banner" src="/src/assets/logos/silhouette_stuttgart_long.svg" alt="Silhouette of Stuttgart" />

        <Disclaimer />

    </div>

</footer>
