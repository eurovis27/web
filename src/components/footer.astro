---
import Disclaimer from '../components/disclaimer.md';
---

<!-- CSS -------------------------------------------------------- -->
<!-- Make it global to also have it applied to included components -->
<style is:global>

    footer {
        text-align:          center;
        background:          rgb(0, 0, 0);
    }

    .disclaimer {
        font-size:           0.8rem;
        color:               rgb(192, 192, 192);
        padding:             1rem;
        padding-right:       2rem;
    } 

    .disclaimer a {
        color:               rgb(192, 192, 192);
    }

    .disclaimer table {
        margin-left: auto;
        margin-right: auto;
    }

    /***** Additional options for Responsive Web Design *****/

    @media screen and (max-width: 1080px) {

    }
    

    @media screen and (max-width: 720px) {

    }      

</style>

<!-- HTML ------------------------------------------------------- -->
<footer>

    <div class="disclaimer">
        <Disclaimer />
    </div>

</footer>
