---
import '../styles/global.css';
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";

import { SEO } from "astro-seo";
import { Font } from "astro:assets";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const colorLightBlue   = "rgb(  0, 190, 255)";
const colorMediumBlue  = "rgb(  0,  65, 145)";
const colorAnthracite  = "rgb( 62,  68,  76)";
const colorOrange      = "rgb(239, 152,   0)";

---

<!-- HTML ------------------------------------------------------- -->
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
		<link rel="icon" href= {import.meta.env.BASE_URL + "favicon.ico"} />
		<!--<link rel="icon" type="image/svg+xml" href= {import.meta.env.BASE_URL + "/favicon.svg"}/> -->    
		<!-- <link rel="stylesheet" href= {import.meta.env.BASE_URL +"/src/styles/global.css"} /> -->
		<title>EuroVis27 - Stuttgart</title>
    <SEO
      title={title}
      titleTemplate="%s - EuroVis 2027"
      description={description}
      canonical="https://eurovis27.github.io/web/"
      noindex={false}
      nofollow={false}
      openGraph={{
        basic: {
          title: title || "EuroVis 2027",
          type: "website",
          image: "/seo-screen.png",
          url: "https://eurovis27.github.io/web/",
        },
        optional: {
          locale: "en_US",
          siteName: "EuroVis 2027",
          description: "{description}"
        },
      }}
    />
    <Font cssVariable="--font-roboto-regular"/>
    <Font cssVariable="--font-roboto-medium"/>
    <Font cssVariable="--font-roboto-bold"/>
    <Font cssVariable="--font-roboto-condensed"/>
	</head>
	<body>

    <Header 
      pageTitle={title} 
      colorLightBlue={colorLightBlue}
      colorMediumBlue={colorMediumBlue}
      colorAnthracite={colorAnthracite}
      colorOrange={colorOrange}
    />


    <div class="content">
      <slot /> <!-- Content of the page -->
    </div>

    <Footer 
      colorLightBlue={colorLightBlue}
      colorMediumBlue={colorMediumBlue}
      colorAnthracite={colorAnthracite}
      colorOrange={colorOrange}
    />
    
	</body>
</html>

<!-- CSS -------------------------------------------------------- -->
<style is:global define:vars={{ colorLightBlue, colorMediumBlue, colorAnthracite, colorOrange }}>

    /* Font color of links */
    a {
        color:                  var(--colorLightBlue);
    }
    a:visited {
        color:                  var(--colorOrange)
    }
    a:hover {
        color:                  var(--colorOrange);
    }


</style>

