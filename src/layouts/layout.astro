---
import '../styles/global.css';
import DSGVO from '../components/dsgvo.md';
import { SEO } from "astro-seo";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href= {import.meta.env.BASE_URL + "/favicon.ico"} />
		<!--<link rel="icon" type="image/svg+xml" href= {import.meta.env.BASE_URL + "/favicon.svg"}/> -->    
		<meta name="generator" content={Astro.generator} />
    <!-- <link rel="stylesheet" href= {import.meta.env.BASE_URL +"/src/styles/global.css"} /> -->
		<title>EuroVis27 - Stuttgart</title>
    <SEO
      title={title}
      titleTemplate="%s - EuroVis 2027"
      description={description}
      canonical="https://eurovis27.github.io/web/"
      noindex={false}
      nofollow={false}
      openGraph={{
        basic: {
          title: title || "EuroVis 2027",
          type: "website",
          image: "/seo-screen.png",
          url: "https://eurovis27.github.io/web/",
        },
        optional: {
          locale: "en_US",
          siteName: "EuroVis 2027",
          description: description,
        },
      }}
    />
	</head>
	<body>

    <div class="dsgvo">
      <DSGVO />
    </div>

    <h1>{title}</h1>

    <h2>{description}</h2>

    <div class="content">
      <slot />
		</div>
    
	</body>
</html>


<!-- Astro prepends BASE_URL automatically to font urls when font-face is defined here -->
<style is:global>

@font-face {
  font-family: 'Supreme-Light';
  src: url('/fonts/Supreme/Supreme-Light.woff2') format('woff2'),
       url('/fonts/Supreme/Supreme-Light.woff') format('woff'),
       url('/fonts/Supreme/Supreme-Light.ttf') format('truetype');
  font-weight: 300;
  font-display: swap;
  font-style: normal;
}

html,
body {
  font-family: 'Supreme-Light', system-ui, -apple-system, sans-serif;
}

</style>
